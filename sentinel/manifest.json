{
  "manifest_version": 3,
  "name": "Network Sentinel",
  "version": "1.0",
  "description": "Blocks ads and popups more efficiently than most ad blockers.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128":"assets/icon.png"
  },
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://*.hianime.to/*",
    "*://*.9anime.pl/*",
    "*://*.aniwatch.to/*",
    "*://*.hdtodayz.to/*",
    "*://*.youtube.com/*"
  ],
  "action": {
    "default_icon": "icon.png",
    "default_popup": "popup.html",
    "default_title": "Toggle Ad Blocking"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.hianime.to/*",
        "*://*.9anime.pl/*",
        "*://*.aniwatch.to/*",
        "*://*.hdtodayz.to/*",
        "*://*.youtube.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules_1.json"
      }
    ]
  }
}
