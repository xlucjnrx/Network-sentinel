{
  "manifest_version": 3,
  "name": "Network Sentinel",
  "...": "...",
  "permissions": [
    "declarativeNetRequest",
    "scripting",
    "activeTab"
  ],
  "host_permissions": ["<all_urls>"],
  "declarative_net_request": {
    "rule_resources": [{
      "id": "block_rules",
      "enabled": true,
      "path": "rules/blocklist.json"
    }]
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }],
  "icons": { ... }
}

